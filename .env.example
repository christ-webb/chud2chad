# Gemini API Key (required for analyze.py)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL for React Native app
# Replace YOUR_LOCAL_IP with your actual local IP address (not localhost)
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000/api

# Backend server port (optional, defaults to 3000)
PORT=3000
